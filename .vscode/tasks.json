{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "promptOnClose": true,
      "type": "shell",
      "command": "bash ./.utils/build_linux.sh vscode-task",
      "group": {
        "kind": "build",
        "isDefault": true
      },
    },
    {
      "label": "Clean Build Cache",
      "promptOnClose": true,
      "type": "shell",
      "command": "rm -rf ./target",
      "group": {
        "kind": "build",
        "isDefault": false
      },
    },
  ]
}